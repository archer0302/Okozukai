          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT t.\"Name\" AS tag,\n       SUM(tx.\"Amount\") AS total_out\nFROM \"Transactions\" tx\nJOIN \"TransactionTags\" tt ON tt.\"TransactionId\" = tx.\"Id\"\nJOIN \"Tags\" t ON t.\"Id\" = tt.\"TagId\"\nWHERE tx.\"Type\" = 'Out'\n  AND $__timeFilter(tx.\"OccurredAt\")\n  AND ('${journal}' = '' OR tx.\"JournalId\" = NULLIF('${journal}', '')::uuid)\nGROUP BY t.\"Name\"\nORDER BY total_out DESC\nLIMIT 10;",
          "refId": "A"
        }
      ],
      "title": "Top Spending Tags",

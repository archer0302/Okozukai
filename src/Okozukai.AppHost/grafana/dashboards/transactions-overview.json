          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('month', \"OccurredAt\") AS time,\n       SUM(CASE WHEN \"Type\" = 'In' THEN \"Amount\" ELSE 0 END) AS total_in,\n       SUM(CASE WHEN \"Type\" = 'Out' THEN \"Amount\" ELSE 0 END) AS total_out,\n       SUM(CASE WHEN \"Type\" = 'In' THEN \"Amount\" ELSE -\"Amount\" END) AS net\nFROM \"Transactions\"\nWHERE $__timeFilter(\"OccurredAt\")\n  AND ('${journal}' = '' OR \"JournalId\" = NULLIF('${journal}', '')::uuid)\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Monthly Income / Expense / Net",
      "type": "timeseries"
